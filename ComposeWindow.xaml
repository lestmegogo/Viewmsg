<Window x:Class="MsgViewer.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MsgViewer"
        mc:Ignorable="d"
        Title="Soạn thư mới - Office 365" Height="620" Width="800"
        WindowStartupLocation="CenterOwner" Background="#f8fafc"
        Foreground="#1e293b" Icon="app_icon.png"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Style for primary button -->
        <Style TargetType="Button" x:Key="SendButton">
            <Setter Property="Background" Value="#0078d4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106ebe" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#c8c6c4" />
                    <Setter Property="Foreground" Value="#a19f9d" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for outline button -->
        <Style TargetType="Button" x:Key="AttachButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#0078d4" />
            <Setter Property="BorderBrush" Value="#0078d4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#eff6ff" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar / Actions -->
            <RowDefinition Height="Auto" /> <!-- To -->
            <RowDefinition Height="Auto" /> <!-- CC -->
            <RowDefinition Height="Auto" /> <!-- Subject -->
            <RowDefinition Height="*" />    <!-- Body -->
            <RowDefinition Height="Auto" /> <!-- Attachments panel -->
            <RowDefinition Height="Auto" /> <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Toolbar / Action buttons -->
        <Border Grid.Row="0" Padding="0,0,0,16" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="✈️ Gửi thư" Style="{StaticResource SendButton}" Click="BtnSend_Click" x:Name="BtnSend"/>
                <Button Content="📎 Đính kèm tệp" Style="{StaticResource AttachButton}" Margin="12,0,0,0" Click="BtnAttach_Click" x:Name="BtnAttach"/>
                <Button Content="✕ Hủy bỏ" Style="{StaticResource AttachButton}" BorderBrush="#ef4444" Foreground="#ef4444" Margin="12,0,0,0" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>

        <!-- Input Fields Group -->
        <!-- To Field -->
        <Grid Grid.Row="1" Margin="0,16,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Đến (To):" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#475569"/>
            <TextBox Grid.Column="1" x:Name="TxtTo" Padding="8,6" BorderBrush="#cbd5e1" BorderThickness="1" FontSize="13" TextChanged="TxtTo_TextChanged" PreviewKeyDown="TxtTo_PreviewKeyDown"/>

            <!-- Suggestions Popup -->
            <Popup x:Name="PopupSuggestions" PlacementTarget="{Binding ElementName=TxtTo}" Placement="Bottom" IsOpen="False" StaysOpen="False" Width="400">
                <Border Background="#ffffff" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="4" MaxHeight="200">
                    <ListBox x:Name="LstSuggestions" BorderThickness="0" Background="Transparent" SelectionChanged="LstSuggestions_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#1f2937" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Email}" Foreground="#64748b" FontSize="11" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Popup>
        </Grid>

        <!-- CC Field -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Cc:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#475569"/>
            <TextBox Grid.Column="1" x:Name="TxtCc" Padding="8,6" BorderBrush="#cbd5e1" BorderThickness="1" FontSize="13"/>
        </Grid>

        <!-- Subject Field -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Tiêu đề:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#475569"/>
            <TextBox Grid.Column="1" x:Name="TxtSubject" Padding="8,6" BorderBrush="#cbd5e1" BorderThickness="1" FontSize="13"/>
        </Grid>

        <!-- Body Rich Text Editor -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Formatting Toolbar -->
            <Border Grid.Row="0" Background="#f8fafc" BorderBrush="#cbd5e1" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="B" FontWeight="Bold" Width="28" Height="26" Margin="0,0,4,0" Style="{StaticResource AttachButton}" Padding="0" Click="BtnFormatBold_Click" ToolTip="Bôi đậm (Ctrl+B)"/>
                    <Button Content="I" FontStyle="Italic" Width="28" Height="26" Margin="0,0,4,0" Style="{StaticResource AttachButton}" Padding="0" Click="BtnFormatItalic_Click" ToolTip="In nghiêng (Ctrl+I)"/>
                    <Button Content="U" Width="28" Height="26" Margin="0,0,4,0" Style="{StaticResource AttachButton}" Padding="0" Click="BtnFormatUnderline_Click" ToolTip="Gạch chân (Ctrl+U)"/>
                    <Separator Width="1" Background="#cbd5e1" Margin="4,3" Height="18"/>
                    <Button Content="• List" Width="48" Height="26" Margin="4,0,4,0" Style="{StaticResource AttachButton}" Padding="0" Click="BtnFormatList_Click" ToolTip="Danh sách dấu chấm"/>
                    <Separator Width="1" Background="#cbd5e1" Margin="4,3" Height="18"/>
                    <Button Content="🎨 Màu" Width="48" Height="26" Margin="4,0,0,0" Style="{StaticResource AttachButton}" Padding="0" Click="BtnFormatColor_Click" ToolTip="Chọn màu chữ"/>
                </StackPanel>
            </Border>

            <!-- RichTextBox for body -->
            <Border Grid.Row="1" Background="White" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="0,0,4,4">
                <RichTextBox x:Name="RtfBody" BorderThickness="0" Padding="12" FontSize="13" VerticalScrollBarVisibility="Auto" AcceptsTab="True" SelectionChanged="RtfBody_SelectionChanged" AllowDrop="True" PreviewDragOver="RtfBody_PreviewDragOver" Drop="RtfBody_Drop"/>
            </Border>
        </Grid>

        <!-- Attachments List Panel -->
        <StackPanel Grid.Row="5" Margin="0,16,0,0" x:Name="PanelAttachments" Visibility="Collapsed">
            <TextBlock Text="TỆP ĐÍNH KÈM" FontSize="10" FontWeight="Bold" Foreground="#64748b" Margin="0,0,0,6"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="LstAttachments">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Attachment Chip -->
                            <Border Background="#ffffff" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="0,0,8,6" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📎" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#334155" VerticalAlignment="Center" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                    <Button Content="✕" Background="Transparent" BorderThickness="0" Foreground="#ef4444" Margin="8,0,0,0" Cursor="Hand" Click="BtnRemoveAttachment_Click" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- Status Bar -->
        <TextBlock Grid.Row="6" x:Name="TxtStatus" Text="Sẵn sàng" Foreground="#64748b" FontSize="11" Margin="0,12,0,0" HorizontalAlignment="Left"/>
    </Grid>
</Window>
