<Window x:Class="MsgViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MsgViewer"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Outlook Mail Viewer" Height="780" Width="1200"
        Background="#f3f4f6" Foreground="#1e293b"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" DragEnter="Window_DragEnter" DragOver="Window_DragOver" Drop="Window_Drop" Icon="app_icon.png">

    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Fill Button Style (Microsoft Blue) -->
        <Style TargetType="Button" x:Key="FillButton">
            <Setter Property="Background" Value="#0078d4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106ebe" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#c8c6c4" />
                    <Setter Property="Foreground" Value="#a19f9d" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Outline Button Style -->
        <Style TargetType="Button" x:Key="OutlineButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#0078d4" />
            <Setter Property="BorderBrush" Value="#0078d4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f3f4f6" />
                    <Setter Property="BorderBrush" Value="#106ebe" />
                    <Setter Property="Foreground" Value="#106ebe" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Action Button Style (Reply, Forward) -->
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#323130" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f3f4f6" />
                    <Setter Property="Foreground" Value="#0078d4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Rounded Brand Button for New Mail -->
        <Style TargetType="Button" x:Key="NewMailButton">
            <Setter Property="Background" Value="#0078d4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106ebe" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Outline Toggle Button Style -->
        <Style TargetType="ToggleButton" x:Key="OutlineToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#0078d4" />
            <Setter Property="BorderBrush" Value="#cbd5e1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="BtnBorder" CornerRadius="4" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#eff6ff" />
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#0078d4" />
                                <Setter Property="Foreground" Value="#0078d4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#f1f5f9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Summarize Button Style -->
        <Style TargetType="Button" x:Key="SummarizeButton">
            <Setter Property="Background" Value="#eff6ff" />
            <Setter Property="Foreground" Value="#1d4ed8" />
            <Setter Property="BorderBrush" Value="#bfdbfe" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#dbeafe" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Selector Style (Focused / Other) -->
        <Style TargetType="RadioButton" x:Key="OutlookTabButton">
            <Setter Property="Foreground" Value="#64748b" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,3" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="GroupName" Value="InboxTabs" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#0078d4" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0078d4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0078d4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBoxItem Style (Vertical blue line on selection) -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="4,0,0,0" Padding="14,10">
                            <!-- Bottom separator border -->
                            <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,0,0,4">
                                <ContentPresenter />
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#f8fafc"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Value="#deecf9" Property="Background"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0078d4" /> <!-- Outlook Blue Line -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimal tab headers at the bottom of detail panel -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#64748b" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,2,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078d4" />
                                <Setter Property="Foreground" Value="#0078d4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0078d4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Ribbon Bar -->
            <RowDefinition Height="*" />    <!-- Main Content -->
            <RowDefinition Height="Auto" /> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR -->
        <Border x:Name="TopRibbonBar" Grid.Row="0" Background="#ffffff" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="0">
            <Grid Height="42">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: File menu with all integrated options -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Button Content="📁 File ∨" FontSize="12" FontWeight="SemiBold" Foreground="#323130" Background="Transparent" BorderThickness="0" Margin="0,0,12,0" VerticalAlignment="Center" Cursor="Hand" Click="BtnFileMenu_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="MnuFileOptions">
                                <MenuItem Header="✉️ Mở tệp email (.msg, .eml)..." Click="MnuFileOpenMsgEml_Click" />
                                <MenuItem Header="📁 Mở thư mục chứa email..." Click="BtnOpenFolder_Click" />
                                <MenuItem Header="📦 Mở tệp tin Outlook Data (.pst, .ost)..." Click="BtnOpenPst_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <!-- Center: Tab Selector -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                    <RadioButton x:Name="RadOutlookWeb" Content="🌐 Outlook Web" Style="{StaticResource OutlookTabButton}" GroupName="MainModes" Height="42" IsChecked="True" Checked="RadOutlookWeb_Checked" Visibility="Collapsed"/>
                    <RadioButton x:Name="RadLocalViewer" Content="📂 Local Viewer" Style="{StaticResource OutlookTabButton}" GroupName="MainModes" Height="42" IsChecked="True" Checked="RadLocalViewer_Checked"/>
                </StackPanel>

                <!-- Right: Office 365 sign-in/out -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Grid x:Name="GridO365SignedOut" Visibility="Visible">
                        <Button Content="🔑 Đăng nhập Office 365" Background="#0078d4" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="12,6" FontWeight="SemiBold" FontSize="11" Click="BtnO365SignIn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <Grid x:Name="GridO365SignedIn" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Background="#0078d4" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock x:Name="TxtO365Avatar" Text="U" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock x:Name="TxtO365Name" Text="User" FontWeight="SemiBold" FontSize="11" Foreground="#1e293b" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                            <TextBlock x:Name="TxtO365Email" Text="" FontSize="9" Foreground="#64748b" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="🚪 Đăng xuất" Style="{StaticResource ActionButton}" Padding="8,4" FontSize="11" Click="BtnO365SignOut_Click" ToolTip="Đăng xuất Office 365"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>



        <!-- MAIN LAYOUT GRID -->
        <Grid x:Name="MainLayoutGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColFolderTree" Width="0" MinWidth="0" /> <!-- Width is 0 (collapsed) by default -->
                <ColumnDefinition x:Name="ColSplitter1" Width="Auto" />
                <ColumnDefinition x:Name="ColEmailList" Width="360" MinWidth="200" />
                <ColumnDefinition x:Name="ColSplitter2" Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

        <!-- NEW LEFT PANEL: Folder TreeView for PST/OST -->
        <Border Grid.Column="0" x:Name="PstFolderPanel" Background="#ffffff" BorderBrush="#e5e7eb" BorderThickness="0,0,1,0" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="Auto" /> <!-- New Mail Button -->
                    <RowDefinition Height="*" /> <!-- TreeView -->
                </Grid.RowDefinitions>
                
                <!-- TreeView Header -->
                <Border Grid.Row="0" Height="42" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M 1,4 L 5,8 L 1,12" Stroke="#323130" StrokeThickness="1.5" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="📁 Folders" FontWeight="Bold" FontSize="12.5" Foreground="#323130" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- New Mail Button for O365 -->
                <Button x:Name="BtnO365NewMail" Grid.Row="1" Content="➕ Thư mới" Style="{StaticResource FillButton}" Height="36" Margin="10,4,10,8" FontSize="12" FontWeight="SemiBold" Click="BtnO365Compose_Click" Visibility="Collapsed"/>
                
                <!-- TreeView -->
                <TreeView Grid.Row="2" x:Name="TreePstFolders" Background="Transparent" BorderThickness="0" Padding="4" SelectedItemChanged="TreePstFolders_SelectedItemChanged">
                    <TreeView.Resources>
                        <ContextMenu x:Key="FolderContextMenu" x:Shared="False" Opened="CtxFolderMenu_Opened">
                            <!-- Header showing item count -->
                            <MenuItem Header="Loading stats..." IsEnabled="False" FontSize="11" FontWeight="SemiBold"/>
                            <Separator />
                            
                            <MenuItem Header="📁 Create new subfolder" Click="MnuCreateSubfolder_Click"/>
                            <MenuItem Header="✏️ Rename" Click="MnuRenameFolder_Click"/>
                            
                            <MenuItem Header="🎨 Change color">
                                <MenuItem Header="🔵 Blue" Click="MnuChangeFolderColor_Click" Tag="Blue"/>
                                <MenuItem Header="🔴 Red" Click="MnuChangeFolderColor_Click" Tag="Red"/>
                                <MenuItem Header="🟢 Green" Click="MnuChangeFolderColor_Click" Tag="Green"/>
                                <MenuItem Header="🟡 Yellow" Click="MnuChangeFolderColor_Click" Tag="Yellow"/>
                            </MenuItem>
                            
                            <MenuItem Header="➡️ Move" Click="MnuMoveFolder_Click"/>
                            <MenuItem Header="🗑️ Delete" Click="MnuDeleteFolder_Click"/>
                            <MenuItem Header="🗑️ Empty folder" Click="MnuEmptyFolder_Click"/>
                            
                            <Separator />
                            
                            <MenuItem Header="✉️ Mark all as read" Click="MnuMarkAllRead_Click"/>
                            
                            <Separator />
                            
                            <MenuItem Header="⭐ Add to Favorites" Click="MnuAddFavorites_Click"/>
                            <MenuItem Header="↑ Move up" Click="MnuMoveUp_Click"/>
                            <MenuItem Header="↓ Move down" Click="MnuMoveDown_Click"/>
                            
                            <Separator Visibility="Collapsed"/>
                            <MenuItem Header="❌ Gỡ bỏ tệp dữ liệu (.pst) khỏi ứng dụng" Click="MnuClosePst_Click" Visibility="Collapsed"/>
                        </ContextMenu>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="Padding" Value="4,2" />
                            <Setter Property="ContextMenu" Value="{StaticResource FolderContextMenu}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TreeViewItem">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Toggle Expander Chevron -->
                                            <ToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Width="16" Height="16" Margin="2,0,2,0" Focusable="False">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="Transparent" Width="16" Height="16">
                                                                        <Path x:Name="Chevron" Data="M 4,2 L 10,8 L 4,14" Stroke="#64748b" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                                            <Path.RenderTransform>
                                                                                <RotateTransform Angle="0"/>
                                                                            </Path.RenderTransform>
                                                                        </Path>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Chevron" Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <RotateTransform Angle="90"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Setter TargetName="Chevron" Property="Stroke" Value="#0078d4" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>

                                            <!-- Content Border -->
                                            <Border x:Name="Bd" Grid.Column="1" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" CornerRadius="4" Padding="6,4" SnapsToDevicePixels="true">
                                                <Grid>
                                                    <Border x:Name="SelectionBar" Width="3" Background="#0078d4" HorizontalAlignment="Left" Margin="-6,0,0,0" Visibility="Collapsed" CornerRadius="1.5"/>
                                                    <ContentPresenter x:Name="PART_Header" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                </Grid>
                                            </Border>

                                            <!-- Items Presenter -->
                                            <ItemsPresenter x:Name="ItemsHost" Grid.Column="1" Grid.Row="1" />
                                        </Grid>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="false">
                                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                            <Trigger Property="HasItems" Value="false">
                                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="true">
                                                <Setter TargetName="Bd" Property="Background" Value="#eff6ff"/>
                                                <Setter TargetName="SelectionBar" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="true" SourceName="Bd">
                                                <Setter TargetName="Bd" Property="Background" Value="#f3f4f6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding SubFolders}">
                            <Grid Width="200" Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,8,0" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#323130" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding UnreadCountText}" FontSize="11" Foreground="#0078d4" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <!-- Splitter 1 (Folder Tree <-> Email List) -->
        <GridSplitter x:Name="Splitter1" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#e2e8f0" ShowsPreview="True" Visibility="Collapsed"/>

        <!-- MIDDLE PANEL: Email List Sidebar -->
        <Border Grid.Column="2" Background="#ffffff" BorderBrush="#e5e7eb" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Search Box -->
                    <RowDefinition Height="Auto" /> <!-- Focused/Other Tabs -->
                    <RowDefinition Height="*" />    <!-- Email List -->
                </Grid.RowDefinitions>

                <Border Grid.Row="1" Height="32" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Background="#ffffff">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RadFilterAll" Content="Tất cả" IsChecked="True" Style="{StaticResource OutlookTabButton}" Checked="FilterTab_Checked" />
                            <RadioButton x:Name="RadFilterUnread" Content="Chưa đọc" Style="{StaticResource OutlookTabButton}" Checked="FilterTab_Checked" Margin="12,0,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="⇅" ToolTip="Sắp xếp" Style="{StaticResource ActionButton}" Padding="4" FontSize="11" Click="BtnSort_Click">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="MnuSort">
                                        <MenuItem Header="Ngày gửi (Mới nhất trước)" Tag="DateDesc" Click="MnuSort_Click" IsChecked="True"/>
                                        <MenuItem Header="Ngày gửi (Cũ nhất trước)" Tag="DateAsc" Click="MnuSort_Click" />
                                        <Separator/>
                                        <MenuItem Header="Người gửi (A-Z)" Tag="FromAsc" Click="MnuSort_Click" />
                                        <MenuItem Header="Người gửi (Z-A)" Tag="FromDesc" Click="MnuSort_Click" />
                                        <Separator/>
                                        <MenuItem Header="Tiêu đề (A-Z)" Tag="SubjectAsc" Click="MnuSort_Click" />
                                        <MenuItem Header="Tiêu đề (Z-A)" Tag="SubjectDesc" Click="MnuSort_Click" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Search Box Panel -->
                <Border Grid.Row="0" Height="Auto" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="8,6">
                    <StackPanel>
                        <!-- Main Search Row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Search Input -->
                            <Border Background="#f3f4f6" BorderThickness="1" BorderBrush="#e5e7eb" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🔍" Grid.Column="0" Foreground="#94a3b8" FontSize="11" Margin="8,0,4,0" VerticalAlignment="Center" />
                                    <TextBox x:Name="TxtSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="2,4" VerticalAlignment="Center" FontSize="12" Foreground="#334155" TextChanged="TxtSearch_TextChanged" GotFocus="TxtSearch_GotFocus" LostFocus="TxtSearch_LostFocus" CaretBrush="#0078d4"/>
                                    <TextBlock x:Name="TxtSearchPlaceholder" Grid.Column="1" Text="Tìm kiếm email..." Foreground="#94a3b8" FontSize="12" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    <Button x:Name="BtnClearSearch" Grid.Column="2" Content="✕" Foreground="#94a3b8" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0" VerticalAlignment="Center" Visibility="Collapsed" Click="BtnClearSearch_Click" Width="18" Height="18" Padding="0" FontSize="10"/>
                                </Grid>
                            </Border>

                            <!-- Advanced Filter Toggle Button -->
                            <ToggleButton Grid.Column="1" x:Name="BtnToggleFilters" Content="⚙️ Bộ lọc" Style="{StaticResource OutlineToggleButton}" Margin="6,0,0,0" Checked="BtnToggleFilters_Checked" Unchecked="BtnToggleFilters_Unchecked"/>
                        </Grid>

                        <!-- Advanced Filters Panel (Collapsible) -->
                        <Grid x:Name="PanelAdvancedFilters" Visibility="Collapsed" Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Scope ComboBox -->
                            <StackPanel Margin="0,0,4,0">
                                <TextBlock Text="Tìm kiếm theo" FontSize="10" Foreground="#64748b" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CboSearchScope" SelectedIndex="0" FontSize="11" Height="24" SelectionChanged="FilterOption_SelectionChanged">
                                    <ComboBoxItem Content="Tất cả các trường" />
                                    <ComboBoxItem Content="Tiêu đề thư" />
                                    <ComboBoxItem Content="Người gửi" />
                                    <ComboBoxItem Content="Người nhận" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Date Filter ComboBox -->
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Thời gian" FontSize="10" Foreground="#64748b" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CboDateFilter" SelectedIndex="0" FontSize="11" Height="24" SelectionChanged="CboDateFilter_SelectionChanged">
                                    <ComboBoxItem Content="Tất cả thời gian" />
                                    <ComboBoxItem Content="Hôm nay" />
                                    <ComboBoxItem Content="Hôm qua" />
                                    <ComboBoxItem Content="Tuần này" />
                                    <ComboBoxItem Content="Tháng này" />
                                    <ComboBoxItem Content="Tháng trước" />
                                    <ComboBoxItem Content="Tự chọn ngày..." />
                                </ComboBox>
                            </StackPanel>

                            <!-- Custom Date Range Row (Collapsible) -->
                            <Grid Grid.Row="1" Grid.ColumnSpan="2" x:Name="GridCustomDateRange" Visibility="Collapsed" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Margin="0,0,4,0">
                                    <TextBlock Text="Từ ngày" FontSize="10" Foreground="#64748b" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="DpStartDate" SelectedDateChanged="DatePicker_SelectedDateChanged" FontSize="11" Height="24"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="đến" VerticalAlignment="Bottom" Margin="4,0,4,4" Foreground="#64748b" FontSize="11"/>

                                <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                    <TextBlock Text="Đến ngày" FontSize="10" Foreground="#64748b" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="DpEndDate" SelectedDateChanged="DatePicker_SelectedDateChanged" FontSize="11" Height="24"/>
                                </StackPanel>
                            </Grid>

                            <!-- CheckBoxes for Attachments & Unread -->
                            <CheckBox Grid.Row="2" Grid.Column="0" x:Name="ChkHasAttachments" Content="Có tệp đính kèm 📎" FontSize="11" Margin="0,10,4,0" VerticalAlignment="Center" Checked="FilterOption_Changed" Unchecked="FilterOption_Changed"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" x:Name="ChkUnreadOnly" Content="Thư chưa đọc ✉️" FontSize="11" Margin="4,10,0,0" VerticalAlignment="Center" Checked="FilterOption_Changed" Unchecked="FilterOption_Changed"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Email ListBox -->
                <Grid Grid.Row="2">
                    <ListView x:Name="LstEmails" 
                              Background="#ffffff" 
                              BorderThickness="0" 
                              HorizontalContentAlignment="Stretch"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              SelectionChanged="LstEmails_SelectionChanged"
                              SizeChanged="LstEmails_SizeChanged">
                        <ListView.Resources>
                            <!-- GridView definition for wide layout -->
                            <GridView x:Key="EmailGridView">
                                <GridViewColumn Header="Người gửi (From)" Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FromClean}" FontWeight="Bold" Foreground="#323130" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Tiêu đề (Subject)" Width="400">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="📎" Visibility="{Binding HasAttachments, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,6,0" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Subject}" Foreground="#323130" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text=" - " Foreground="#64748b" FontSize="11.5" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Snippet}" Foreground="#64748b" TextTrimming="CharacterEllipsis" FontSize="11.5" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Thời gian (Received)" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DateDisplay}" Foreground="#64748b" VerticalAlignment="Center" FontSize="11.5"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                <Grid>
                                                    <Border x:Name="SelectionBar" Width="3.5" Background="#0078d4" HorizontalAlignment="Left" Margin="-12,-10,0,-10" Visibility="Collapsed" CornerRadius="0"/>
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="true">
                                                    <Setter TargetName="Bd" Property="Background" Value="#f3f4f6"/>
                                                    <Setter TargetName="SelectionBar" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter TargetName="Bd" Property="Background" Value="#f9fafb"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                    <Setter TargetName="SelectionBar" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#f8fafc" Padding="12,5" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="10.5" Foreground="#64748b"/>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0">
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="↩️ Trả lời" Click="MenuReply_Click" />
                                            <MenuItem Header="🔂 Trả lời tất cả" Click="MenuReplyAll_Click" />
                                            <MenuItem Header="➡️ Chuyển tiếp" Click="MenuForward_Click" />
                                            <Separator />
                                            <MenuItem Header="✉️ Đánh dấu Đọc/Chưa đọc" Click="MenuMarkRead_Click" />
                                            <MenuItem Header="📦 Lưu trữ" Click="MenuArchive_Click" />
                                            <MenuItem Header="🗑️ Xóa" Click="MenuDelete_Click" />
                                            <Separator />
                                            <MenuItem Header="🚫 Báo cáo thư rác (Junk)" Click="MenuJunk_Click" />
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Multi-select Checkbox & Avatar Circle Container -->
                                    <Grid Grid.Column="0" Grid.RowSpan="3" Width="36" Height="36" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <!-- CheckBox (visible on hover or checked) -->
                                        <CheckBox x:Name="ChkSelectEmail" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay}" Checked="ChkSelectEmail_Checked" Unchecked="ChkSelectEmail_Unchecked" Tag="{Binding}">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>

                                        <!-- Avatar Circle (visible by default, collapsed when checkbox is visible) -->
                                        <Border Width="32" Height="32" CornerRadius="16" Background="#b2dfdb" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=ChkSelectEmail, Path=Visibility}" Value="Visible">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SenderInitials}" Foreground="#004d40" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Sender Name -->
                                    <TextBlock Grid.Column="1" Grid.Row="0" 
                                               local:TextBlockHelper.HighlightText="{Binding FromClean}"
                                               local:TextBlockHelper.Keyword="{Binding Path=SearchKeyword, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontWeight="Bold" Foreground="#323130" FontSize="12.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                    <!-- Date/Time -->
                                    <TextBlock Grid.Column="2" Grid.Row="0" Text="{Binding DateDisplay}" FontSize="10.5" Margin="8,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#64748b" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                        <Setter Property="Foreground" Value="#0078d4" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Hover Quick Actions Panel -->
                                    <StackPanel Grid.RowSpan="3" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Button Content="✉️" Style="{StaticResource ActionButton}" Padding="4" FontSize="10" Margin="0,0,4,0" ToolTip="Đánh dấu Đọc/Chưa đọc" Click="BtnQuickToggleRead_Click"/>
                                        <Button Content="🗑️" Style="{StaticResource ActionButton}" Padding="4" FontSize="10" ToolTip="Xóa nhanh" Click="BtnQuickDelete_Click"/>
                                    </StackPanel>

                                    <!-- Subject (Blue if unread) -->
                                    <TextBlock Grid.Row="1" Grid.Column="1" 
                                               local:TextBlockHelper.HighlightText="{Binding Subject}"
                                               local:TextBlockHelper.Keyword="{Binding Path=SearchKeyword, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontSize="11.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#323130" />
                                                <Setter Property="FontWeight" Value="Normal" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                        <Setter Property="Foreground" Value="#0078d4" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Attachment Icon -->
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="📎" Foreground="#64748b" FontSize="11" Margin="8,2,0,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Snippet/Preview -->
                                    <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" 
                                               local:TextBlockHelper.HighlightText="{Binding Snippet}"
                                               local:TextBlockHelper.Keyword="{Binding Path=SearchKeyword, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Foreground="#64748b" FontSize="11" Margin="0,3,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty List Placeholder -->
                    <Border x:Name="BdrEmptyList" Background="#ffffff" Visibility="Visible" Padding="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📥" FontSize="40" Foreground="#cbd5e1" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Chưa nạp email nào" FontSize="13" FontWeight="SemiBold" Foreground="#64748b" HorizontalAlignment="Center"/>
                            <TextBlock Text="Chọn tệp/thư mục hoặc thả các tệp tin email vào đây." TextWrapping="Wrap" Foreground="#94a3b8" FontSize="11" TextAlignment="Center" Margin="0,6,0,0" MaxWidth="260"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Splitter 2 (Email List <-> Email Detail) -->
        <GridSplitter x:Name="Splitter2" Grid.Column="3" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#e2e8f0" ShowsPreview="True"/>

        <!-- RIGHT PANEL: Email Detail Reader -->
        <Grid Grid.Column="4" Background="#f8fafc">
            <!-- No Selection Placeholder -->
            <Grid x:Name="GridPlaceholder" Background="#f3f4f6" Panel.ZIndex="10" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="✉️" FontSize="60" Foreground="#cbd5e1" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Chọn một email trong danh sách để đọc" FontSize="15" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kéo thả tệp .msg, .eml hoặc thư mục chứa email vào bất kỳ đâu." FontSize="11" Foreground="#94a3b8" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Email Detail Layout -->
            <Grid x:Name="GridDetail" Background="#ffffff">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header Metadata (Subject, From, To, CC, Date, Action buttons) -->
                    <RowDefinition Height="Auto" /> <!-- Attachments Chips -->
                    <RowDefinition Height="*" />    <!-- Content Body Tabs -->
                    <RowDefinition Height="Auto" /> <!-- Bottom Action Buttons -->
                </Grid.RowDefinitions>

                <!-- Subject, Sender Card -->
                <Border Grid.Row="0" Background="#ffffff" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1" Padding="20,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 1. Large Subject Title -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtSubject" Text="Tiêu đề email" FontSize="16" FontWeight="Bold" Foreground="#323130" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BtnO365Archive" Content="📦 Archive" Style="{StaticResource ActionButton}" Margin="8,0,0,0" Click="BtnO365Archive_Click" Visibility="Collapsed"/>
                                <Button x:Name="BtnO365Delete" Content="🗑️ Delete" Style="{StaticResource ActionButton}" Margin="6,0,0,0" Click="BtnO365Delete_Click" Visibility="Collapsed"/>
                                <Button Content="✨ Summarize with AI" Style="{StaticResource SummarizeButton}" Margin="12,0,0,0" Click="BtnSummarize_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- 2. Sender Profile Card -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Avatar Circle -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#0078d4" VerticalAlignment="Top" Margin="0,0,12,0">
                                <TextBlock x:Name="TxtAvatar" Text="AB" Foreground="White" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- From, To, CC info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                <TextBlock x:Name="TxtFrom" Text="Người gửi &lt;email@example.com&gt;" FontWeight="Bold" Foreground="#323130" FontSize="12.5" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtTo" Text="To: N/A" Foreground="#64748b" FontSize="11.5" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtCc" Text="Cc: N/A" Foreground="#64748b" FontSize="11.5" Margin="0,3,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                            </StackPanel>

                            <!-- Date/Time & Small Quick Reply Bar -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtDate" Text="Này nọ kia" Foreground="#64748b" FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BtnDetailReply" Content="↩️ Reply" Style="{StaticResource ActionButton}" Padding="6,4" FontSize="11" Click="BtnReply_Click"/>
                                    <Button x:Name="BtnDetailReplyAll" Content="🔂 Reply all" Margin="4,0,0,0" Style="{StaticResource ActionButton}" Padding="6,4" FontSize="11" Click="BtnReplyAll_Click"/>
                                    <Button x:Name="BtnDetailForward" Content="➡️ Forward" Margin="4,0,0,0" Style="{StaticResource ActionButton}" Padding="6,4" FontSize="11" Click="BtnForward_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Horizontal Attachments List (Chips) -->
                <Border x:Name="CardAttachments" Grid.Row="1" Background="#f8fafc" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1" Padding="20,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="ĐÍNH KÈM" FontSize="10" FontWeight="Bold" Foreground="#64748b" Margin="0,0,0,6"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="LstAttachments">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Attachment Chip Style -->
                                        <Border Background="#ffffff" BorderBrush="#d1d5db" BorderThickness="1" CornerRadius="16" Padding="12,6" Margin="0,4,8,4" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📎" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding FileName}" FontSize="11" FontWeight="SemiBold" Foreground="#1f2937" MaxWidth="180" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip="{Binding FileName}"/>
                                                <TextBlock Text="{Binding SizeDisplay, StringFormat=' ({0})'}" FontSize="10" Foreground="#64748b" VerticalAlignment="Center"/>
                                                <Button Content="Mở" Style="{StaticResource ActionButton}" Margin="10,0,0,0" Padding="6,2" FontSize="10" Click="BtnOpenAttachment_Click"/>
                                                <Button Content="Lưu" Style="{StaticResource ActionButton}" Margin="2,0,0,0" Padding="6,2" FontSize="10" Click="BtnSaveAttachment_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Main Content Tabs -->
                <TabControl Grid.Row="2" Background="#ffffff" BorderThickness="0" TabStripPlacement="Bottom">
                    <!-- HTML Render Tab -->
                    <TabItem Header="Xem giao diện (HTML)">
                        <Grid>
                            <wpf:WebView2 x:Name="EmailWebView" AllowExternalDrop="False" />
                        </Grid>
                    </TabItem>

                    <!-- Plain Text Tab -->
                    <TabItem Header="Xem văn bản (Plain Text)">
                        <TextBox x:Name="TxtBodyText" 
                                 IsReadOnly="True" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto" 
                                 Background="#ffffff" 
                                 Foreground="#1e293b" 
                                 BorderThickness="0" 
                                 Padding="20" 
                                 FontSize="13" 
                                 FontFamily="Segoe UI"/>
                    </TabItem>

                    <!-- SMTP Headers Tab -->
                    <TabItem Header="Tiêu đề thư (Headers)">
                        <TextBox x:Name="TxtHeaders" 
                                 IsReadOnly="True" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto" 
                                 Background="#ffffff" 
                                 Foreground="#475569" 
                                 BorderThickness="0" 
                                 Padding="20" 
                                 FontSize="11" 
                                 FontFamily="Consolas"/>
                    </TabItem>
                </TabControl>

                <!-- Bottom Inline Rich Editor Panel (Initially Hidden, Expands when Active) -->
                <Border Grid.Row="3" x:Name="BdrInlineEditor" Background="#ffffff" BorderBrush="#e5e7eb" BorderThickness="0,1,0,0" Padding="20,12" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- Action Label / Action Type Indicator -->
                                <RowDefinition Height="Auto" /> <!-- Recipients Inputs (To, Cc) -->
                                <RowDefinition Height="Auto" /> <!-- Formatting Toolbar -->
                                <RowDefinition Height="180" />  <!-- RichTextBox Body Editor -->
                                <RowDefinition Height="Auto" /> <!-- Attachment Chips -->
                                <RowDefinition Height="Auto" /> <!-- Send/Discard Action Bar -->
                            </Grid.RowDefinitions>

                            <!-- Row 0: Action Label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock x:Name="TxtInlineActionType" Text="↩️ Replying to sender..." FontSize="12" FontWeight="SemiBold" Foreground="#0078d4" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Row 1: Recipients inputs (To, Cc) -->
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="To:" FontSize="11.5" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,8,0" Width="24"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtInlineTo" FontSize="12" Padding="4,3" BorderBrush="#cbd5e1" BorderThickness="0,0,0,1" Margin="0,0,0,6" Background="Transparent"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Cc:" FontSize="11.5" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,8,0" Width="24"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtInlineCc" FontSize="12" Padding="4,3" BorderBrush="#cbd5e1" BorderThickness="0,0,0,1" Background="Transparent"/>
                            </Grid>

                            <!-- Row 2: Formatting Toolbar -->
                            <Border Grid.Row="2" Background="#f3f4f6" CornerRadius="4,4,0,0" Padding="8,4" BorderBrush="#cbd5e1" BorderThickness="1,1,1,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="B" FontWeight="Bold" Style="{StaticResource ActionButton}" Width="24" Height="24" Padding="0" Click="BtnInlineBold_Click" ToolTip="Bold (Ctrl+B)"/>
                                    <Button Content="I" FontStyle="Italic" Style="{StaticResource ActionButton}" Width="24" Height="24" Padding="0" Click="BtnInlineItalic_Click" ToolTip="Italic (Ctrl+I)" Margin="4,0,0,0"/>
                                    <Button Content="U" Style="{StaticResource ActionButton}" Width="24" Height="24" Padding="0" Click="BtnInlineUnderline_Click" ToolTip="Underline (Ctrl+U)" Margin="4,0,0,0"/>
                                    <Separator Width="1" Background="#cbd5e1" Margin="6,4" Height="16"/>
                                    <Button Content="🎨 Blue" Foreground="#0078d4" Style="{StaticResource ActionButton}" Padding="4,0" FontSize="11" Click="BtnInlineBlueText_Click" ToolTip="Text Color Blue" Height="24"/>
                                    <Separator Width="1" Background="#cbd5e1" Margin="6,4" Height="16"/>
                                    <Button Content="📎 Attach file" Style="{StaticResource ActionButton}" Padding="6,0" FontSize="11" Click="BtnInlineAttach_Click" ToolTip="Đính kèm tệp tin" Height="24"/>
                                </StackPanel>
                            </Border>

                            <!-- Row 3: Body RichTextBox -->
                            <RichTextBox Grid.Row="3" x:Name="RtfInlineBody" BorderBrush="#cbd5e1" BorderThickness="1" Padding="10" VerticalScrollBarVisibility="Auto" FontSize="12.5" FontFamily="Segoe UI" AcceptsReturn="True" AllowDrop="True" PreviewDragOver="RtfInlineBody_PreviewDragOver" Drop="RtfInlineBody_Drop"/>

                            <!-- Row 4: Attachment List -->
                            <ItemsControl Grid.Row="4" x:Name="LstInlineAttachments" Margin="0,6,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#f3f4f6" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="0,0,6,6" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📎" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding FileName}" FontSize="10.5" Foreground="#323130" MaxWidth="140" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Button Content="✕" Foreground="#ef4444" Style="{StaticResource ActionButton}" Padding="4,0" FontSize="9" Margin="6,0,0,0" Click="BtnInlineRemoveAttachment_Click" Tag="{Binding FilePath}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Row 5: Action Buttons (Send, Discard) -->
                            <Grid Grid.Row="5" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="Send" Width="90" Height="30" Style="{StaticResource FillButton}" Click="BtnInlineSend_Click" />
                                    <Button Content="Discard" Width="90" Height="30" Style="{StaticResource OutlineButton}" Click="BtnInlineDiscard_Click" Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock x:Name="TxtInlineDraftStatus" Text="" Foreground="#64748b" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                <!-- Summary Overlay Popup -->
                <Border x:Name="BdrSummaryPopup" Grid.Row="0" Grid.RowSpan="4" Panel.ZIndex="100" Background="#80000000" Visibility="Collapsed" MouseDown="BdrSummaryPopup_MouseDown">
                    <Border Background="#ffffff" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="8" Padding="24" Width="550" Height="450" HorizontalAlignment="Center" VerticalAlignment="Center" MouseDown="BdrSummaryPopup_InnerMouseDown">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="✨ Tóm tắt Email (AI Summary)" FontSize="16" FontWeight="Bold" Foreground="#0078d4" Margin="0,0,0,12"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#f8fafc" Padding="12" BorderThickness="1" BorderBrush="#e2e8f0">
                                <TextBlock x:Name="TxtSummaryContent" Text="Nội dung tóm tắt..." FontSize="13" Foreground="#334155" TextWrapping="Wrap" LineHeight="1.6" FontFamily="Segoe UI"/>
                            </ScrollViewer>

                            <Button Grid.Row="2" Content="Đóng" HorizontalAlignment="Right" Margin="0,16,0,0" Padding="16,6" Style="{StaticResource FillButton}" Click="BtnCloseSummary_Click"/>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Grid>

        </Grid> <!-- CLOSE MAIN LAYOUT GRID -->

        <!-- Outlook Web Overlay (full area when O365 active) -->
        <Grid x:Name="OutlookWebOverlay" Grid.Row="1" Visibility="Collapsed" Background="#ffffff">
            <wpf:WebView2 x:Name="OutlookWebView" AllowExternalDrop="False" />
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="5" Background="#f3f4f6" BorderBrush="#e5e7eb" BorderThickness="0,1,0,0" Padding="12,5">
            <TextBlock x:Name="TxtStatus" Text="Sẵn sàng. Kéo thả file email/thư mục để xem." Foreground="#64748b" FontSize="11" />
        </StatusBar>

    </Grid>
</Window>
